{
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(which:*)"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/*.keystore)",
      "Read(**/*.jks)",
      "Read(**/id_rsa)",
      "Read(**/id_rsa.*)",
      "Read(**/id_ed25519)",
      "Read(**/id_ecdsa)",
      "Read(**/secrets/**)",
      "Read(**/.secrets/**)",
      "Read(**/.npmrc)",
      "Read(**/.pypirc)",
      "Read(**/.netrc)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.kube/config)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.docker/config.json)",
      "Read(~/.config/claude/.claude.json)",
      "Read(~/.claude/.claude.json)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Edit(**/*.pem)",
      "Edit(**/*.key)",
      "Edit(**/*.p12)",
      "Edit(**/*.pfx)",
      "Edit(**/*.keystore)",
      "Edit(**/*.jks)",
      "Edit(**/id_rsa)",
      "Edit(**/id_rsa.*)",
      "Edit(**/id_ed25519)",
      "Edit(**/id_ecdsa)",
      "Edit(**/secrets/**)",
      "Edit(**/.secrets/**)",
      "Edit(**/.npmrc)",
      "Edit(**/.pypirc)",
      "Edit(**/.netrc)",
      "Edit(~/.ssh/**)",
      "Edit(~/.aws/**)",
      "Edit(~/.gnupg/**)",
      "Edit(~/.kube/config)",
      "Edit(~/.config/gcloud/**)",
      "Edit(~/.docker/config.json)",
      "Edit(~/.config/claude/.claude.json)",
      "Edit(~/.claude/.claude.json)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Write(**/*.pem)",
      "Write(**/*.key)",
      "Write(**/*.p12)",
      "Write(**/*.pfx)",
      "Write(**/*.keystore)",
      "Write(**/*.jks)",
      "Write(**/id_rsa)",
      "Write(**/id_rsa.*)",
      "Write(**/id_ed25519)",
      "Write(**/id_ecdsa)",
      "Write(**/secrets/**)",
      "Write(**/.secrets/**)",
      "Write(**/.npmrc)",
      "Write(**/.pypirc)",
      "Write(**/.netrc)",
      "Write(~/.ssh/**)",
      "Write(~/.aws/**)",
      "Write(~/.gnupg/**)",
      "Write(~/.kube/config)",
      "Write(~/.config/gcloud/**)",
      "Write(~/.docker/config.json)",
      "Write(~/.config/claude/.claude.json)",
      "Write(~/.claude/.claude.json)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)"
    ],
    "ask": [
      "Bash(sudo:*)",
      "Bash(git push:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)"
    ],
    "disableBypassPermissionsMode": "disable"
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "agent-sdk-dev@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "session-report@claude-plugins-official": true
  },
  "sandbox": {
    "enabled": true,
    "filesystem": {
      "denyRead": [
        "~/.ssh/**",
        "~/.aws/**",
        "~/.gnupg/**",
        "~/.config/gcloud/**",
        "~/.kube/config",
        "~/.docker/config.json",
        "~/.config/claude/.claude.json",
        "~/.claude/.claude.json",
        "**/.env",
        "**/.env.*",
        "**/*.pem",
        "**/*.key",
        "**/*.p12",
        "**/*.pfx",
        "**/*.keystore",
        "**/*.jks",
        "**/id_rsa",
        "**/id_rsa.*",
        "**/id_ed25519",
        "**/id_ecdsa",
        "**/secrets/**",
        "**/.secrets/**",
        "**/.npmrc",
        "**/.pypirc",
        "**/.netrc"
      ]
    }
  },
  "theme": "dark"
}
